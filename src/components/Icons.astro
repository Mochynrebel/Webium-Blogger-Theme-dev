---
const { name, className = "icon" } = Astro.props;

const icons = {
  home: `<path d="M3.75 10.5 12 4l8.25 6.5v8.25a1 1 0 0 1-1 1H14v-5h-4v5H4.75a1 1 0 0 1-1-1Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>`,
  note: `<path d="M7 4.75h7l4 4v10.5a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1v-13.5a1 1 0 0 1 1-1Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.5"/><path d="M14 4.75v4h4" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.5"/><path d="M9 13h6M9 16h6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.5"/>`,
  tag: `<path d="M4.75 8.25V5.5a1 1 0 0 1 1-1H10l8.25 8.25a1.5 1.5 0 0 1 0 2.12l-3.38 3.38a1.5 1.5 0 0 1-2.12 0L4.75 10.25Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.5"/><circle cx="8.25" cy="8" r="1.25" fill="currentColor"/>`,
  moon: `<path d="M19 14.5A7.5 7.5 0 0 1 9.5 5a7.5 7.5 0 1 0 9.5 9.5Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.5"/>`,
  sun: `<circle cx="12" cy="12" r="3.5" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M12 2.75v2.5M12 18.75v2.5M21.25 12h-2.5M5.25 12h-2.5M18.54 5.46l-1.77 1.77M7.23 16.77l-1.77 1.77M18.54 18.54l-1.77-1.77M7.23 7.23 5.46 5.46" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.5"/>`,
  arrow: `<path d="M5 12h13M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>`
};
---

<svg
  class={className}
  xmlns="http://www.w3.org/2000/svg"
  width="22"
  height="22"
  viewBox="0 0 24 24"
  aria-hidden="true"
  set:html={icons[name]}
/>
