---
import preview from "../assets/images/preview.png";
import ArticleCard from "../components/ArticleCard.astro";
import Icons from "../components/Icons.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../utils/blog";

const posts = await getPublishedPosts();
const [featured, ...rest] = posts;
const latest = rest.slice(0, 4);
const categories = [...new Set(posts.map((post) => post.data.category))];
---

<BaseLayout>
  <section class="hero-card">
    <div class="hero-grid">
      <div class="hero-copy">
        <div class="eyebrow">Astro Editorial Theme</div>
        <h1 class="hero-title">A publishing layout rebuilt for Vercel.</h1>
        <p>
          Webium now ships as a real Astro blog. You can write in Markdown, deploy
          on every push, and keep the clean reading-first feel of the original
          theme.
        </p>
        <div class="button-row">
          <a class="button-link primary" href={featured ? `/blog/${featured.slug}/` : "/about"}>
            Read the featured story
          </a>
          <a class="button-link" href="/tags">Browse by tag</a>
        </div>
      </div>
      <div class="hero-media">
        <div class="hero-preview">
          <img src={preview.src} alt="Webium editorial preview" />
        </div>
      </div>
    </div>
  </section>

  <div class="content-grid">
    <section class="stack">
      {featured && (
        <article class="post-card">
          <div class="small-label">Featured</div>
          <h2>
            <a href={`/blog/${featured.slug}/`}>{featured.data.title}</a>
          </h2>
          <p>{featured.data.description}</p>
          <div class="meta-row">
            <span>{featured.data.author}</span>
            <span>•</span>
            <span>{featured.data.category}</span>
          </div>
        </article>
      )}

      <div class="post-list">
        {latest.map((post) => (
          <ArticleCard post={post} />
        ))}
      </div>
    </section>

    <aside class="stack">
      <section class="panel">
        <h2>What changed</h2>
        <div class="simple-list">
          <p>Blogger XML was removed from the runtime path.</p>
          <p>Posts now live in Markdown content collections.</p>
          <p>The output is static and deploys cleanly to Vercel.</p>
        </div>
      </section>

      <section class="panel">
        <h2>Explore sections</h2>
        <div class="pill-row">
          {categories.map((category) => (
            <span class="tag-pill">{category}</span>
          ))}
        </div>
      </section>

      <section class="panel">
        <h2>Publishing workflow</h2>
        <p>
          Add new posts in <code>src/content/blog</code>, then run
          <code>npm run dev</code> locally or push directly to Vercel.
        </p>
        <a class="text-link" href="/about">
          Read the migration notes <Icons name="arrow" className="icon" />
        </a>
      </section>
    </aside>
  </div>
</BaseLayout>
